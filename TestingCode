SCRIPT AREA
START SCRIPT
DECLARE INT hour, minute, convertedHour 
SCAN: hour, minute 
IF (hour<0 OR hour>23 OR minute<0 OR minute>59)  
START IF
	PRINT: "Invalid time."
END IF
ELSE
START IF
	convertedHour = hour
	IF (hour==0)  
	START IF 
		convertedHour = 12
            	PRINT: convertedHour & [:] & minute & "AM"
        END IF
        ELSE IF (hour>0 AND hour<12)  
	START IF 
		convertedHour = hour
            	PRINT: convertedHour & [:] & minute & "AM"
        END IF
	ELSE IF (hour==12)  
	START IF 
		convertedHour = 12
            	PRINT: convertedHour & [:] & minute & "PM"
        END IF
	ELSE
	START IF
		convertedHour = hour - 12
            	PRINT: convertedHour & [:] & minute & "PM"
        END IF
 
END IF 
END SCRIPT